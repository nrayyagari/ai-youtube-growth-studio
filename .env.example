# AI YouTube Growth Studio — Environment Variables
# Copy this file to .env and fill in your values.

# Database
DATABASE_URL=sqlite:///./data/growth_studio.db

# AI Provider API Keys (supports comma-separated keys per provider for cycling)
# Gemini 2.0 Flash — free tier available
GEMINI_API_KEY=

# Groq (Llama 3.3 70B) — free tier available at console.groq.com
GROK_API_KEY=

# Cerebras (Llama 3.3 70B) — free tier available at cloud.cerebras.ai
CEREBRAS_API_KEY=

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# YouTube API (optional — for YouTube Analytics integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/oauth/callback

# SaaS monetization (optional for local mode)
# Clerk sends X-Clerk-User-Id after frontend auth. Without it, the app uses a local dev user.
CLERK_WEBHOOK_SECRET=

# Stripe checkout/webhooks. Without keys, checkout returns a local placeholder URL.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
APP_BASE_URL=http://localhost:5173
