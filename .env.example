# AI YouTube Growth Studio — Environment Variables
# Copy this file to .env and fill in your values.

# AI Provider API Keys (supports comma-separated keys per provider for cycling)
# Users can also bring their own keys via Settings page — these are server defaults.
# Gemini 2.0 Flash — free tier available at aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (Llama 3.3 70B) — free tier available at console.groq.com
GROQ_API_KEY=

# Cerebras (Llama 3.3 70B) — free tier available at cloud.cerebras.ai
CEREBRAS_API_KEY=

# DeepSeek V3 — at platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI — at platform.openai.com
OPENAI_API_KEY=

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Auth — generate a strong secret
JWT_SECRET=change-me-in-production

# OTP / Email — for email-based login
# Use Resend (resend.com) — 100 emails/day free
RESEND_API_KEY=
# Or use SMTP (Gmail, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@growthstudio.app

# YouTube API (optional — for YouTube Analytics integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/oauth/callback

APP_BASE_URL=http://localhost:5173
